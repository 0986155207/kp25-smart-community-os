{
  "name": "kp25-smart-community-os",
  "version": "1.0.0",
  "private": true,
  "description": "Hệ điều hành số cộng đồng - Khu phố 25, Long Trường, TP.HCM",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "npm run dev --workspace=@kp25/web",
    "dev:admin": "npm run dev --workspace=@kp25/admin",
    "kill:ports": "npx kill-port 3000 3001 || true",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:unit": "turbo run test",
    "test:unit:web": "npm run test --workspace=@kp25/web",
    "test:unit:admin": "npm run test --workspace=@kp25/admin",
    "test:coverage": "turbo run test:coverage",
    "test:e2e": "playwright test",
    "test:e2e:portal": "playwright test --project=portal-desktop",
    "test:e2e:admin": "playwright test --project=admin-desktop",
    "test:e2e:mobile": "playwright test --project=portal-mobile",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:all": "turbo run test && playwright test",
    "clean": "turbo run clean && rimraf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:push": "cd packages/database && npx prisma db push",
    "db:generate": "cd packages/database && npx prisma generate",
    "db:studio": "cd packages/database && npx prisma studio",
    "db:migrate": "cd packages/database && npx prisma migrate dev"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.8.2"
}
