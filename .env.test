# ─── Test Environment ────────────────────────────────────────
# Sử dụng khi chạy unit tests (Vitest)
# KHÔNG commit file này nếu có thông tin nhạy cảm

# Supabase (dùng project test riêng hoặc mock)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=test-anon-key
SUPABASE_SERVICE_ROLE_KEY=test-service-role-key

# Gemini AI (mock trong tests)
GEMINI_API_KEY=test-gemini-key

# E2E Test credentials (KHÔNG đặt password thật ở đây)
# TEST_ADMIN_EMAIL=your-admin@email.com
# TEST_ADMIN_PASSWORD=your-password

# Playwright base URLs
PLAYWRIGHT_WEB_URL=http://localhost:3000
PLAYWRIGHT_ADMIN_URL=http://localhost:3001
