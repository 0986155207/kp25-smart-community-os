# ============================================
# KP25 SMART COMMUNITY OS — Environment Config
# Sao chép file này thành .env và điền giá trị
# ============================================

# --- SUPABASE ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI (GEMINI) ---
# QUAN TRỌNG (đa khu phố): mỗi khu phố dùng KHÓA GEMINI RIÊNG.
# Mỗi Vercel project đặt khóa của chính khu phố đó → tách hạn mức/chi phí.
GEMINI_API_KEY=your-gemini-api-key
# Model: gemini-2.5-flash

# --- KHU PHỐ (ĐA KHU PHỐ / MULTI-TENANT) ---
# Mỗi bản triển khai (Vercel project) đặt các biến này để xác định khu phố của mình.
# Bỏ trống = mặc định Khu phố 25. Xem docs/chia-se-cho-khu-pho-khac.md
NEXT_PUBLIC_KP_ID=00000000-0000-4000-8000-000000000025   # UUID trong bảng don_vi (lọc dữ liệu)
NEXT_PUBLIC_KP_SLUG=kp25                                   # định danh đường dẫn
NEXT_PUBLIC_KP_MA=KP25                                     # mã ngắn (dùng cho logo, mã hộ)
NEXT_PUBLIC_KP_TEN=Khu phố 25                              # tên hiển thị trên giao diện
NEXT_PUBLIC_KP_TEN_DAY_DU=Khu phố 25, Phường Long Trường, TP. Hồ Chí Minh
NEXT_PUBLIC_KP_PHUONG=Phường Long Trường
NEXT_PUBLIC_KP_MAU=#8B1A1A                                 # màu chủ đạo (hex) — dùng cho cả favicon động
NEXT_PUBLIC_KP_LOGO_CHU=KP                                 # phần chữ trên logo
NEXT_PUBLIC_KP_LOGO_SO=25                                  # phần số trên logo (màu vàng)
NEXT_PUBLIC_KP_LOGO_URL=                                   # (tùy chọn) URL ảnh logo riêng; bỏ trống = dùng logo chữ
# Ghi chú: favicon + icon PWA + manifest được SINH ĐỘNG từ các biến trên
# (src/app/icon.tsx, apple-icon.tsx, manifest.ts) → không cần upload file ảnh.

# --- JWT ---
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# --- APP ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=KP25 Smart Community OS
NEXT_PUBLIC_KHU_PHO=Khu phố 25
NEXT_PUBLIC_PHUONG=Phường Long Trường
NEXT_PUBLIC_THANH_PHO=TP.HCM

# --- API ---
API_URL=http://localhost:4000
API_PORT=4000

# --- REDIS ---
REDIS_URL=redis://localhost:6379

# --- SMS/OTP (Twilio hoặc ESMS.vn) ---
SMS_PROVIDER=esms
ESMS_API_KEY=your-esms-key
ESMS_SECRET_KEY=your-esms-secret
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- ZALO OA ---
# Đăng ký tại: https://developers.zalo.me
# OA đang chờ phê duyệt — điền sau khi được Zalo cấp
ZALO_APP_ID=
ZALO_APP_SECRET=
ZALO_OA_ID=
ZALO_OA_ACCESS_TOKEN=
ZALO_OA_REFRESH_TOKEN=
ZALO_OA_STATUS=PENDING          # PENDING | ACTIVE
ZALO_WEBHOOK_VERIFY_TOKEN=kp25_zalo_webhook

# URLs Zalo — hiển thị trên portal người dân
NEXT_PUBLIC_ZALO_OA_URL=        # https://zalo.me/oa_id
NEXT_PUBLIC_ZALO_GROUP_URL=     # https://zalo.me/g/group_id
NEXT_PUBLIC_ZALO_GROUP_QR=      # URL ảnh QR code của nhóm

# URL của app web (dùng để gọi API từ admin server actions)
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# --- STORAGE ---
NEXT_PUBLIC_STORAGE_URL=https://your-project.supabase.co/storage/v1
STORAGE_BUCKET=kp25-uploads

# --- MAPS ---
NEXT_PUBLIC_MAP_CENTER_LAT=10.8231
NEXT_PUBLIC_MAP_CENTER_LNG=106.6297
NEXT_PUBLIC_MAP_ZOOM=15

# --- NODE ---
NODE_ENV=development
